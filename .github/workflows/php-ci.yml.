ame: PHP Continuous Integration
on:
push:
branches: [ "main", "desarrollo" ]
pull_request:
branches: [ "main", "desarrollo" ]
jobs:
build-and-test:
runs-on: ubuntu-latest
steps:
- name: Descargar Código del Repositorio
uses: actions/checkout@v3
- name: Configurar Entorno PHP
uses: shivammathur/setup-php@v2
with:
php-version: '8.2'
extensions: mbstring, xml
- name: Instalar Dependencias de Composer
run: composer install --no-progress --pref-dist
- name: Ejecutar Pruebas Unitarias (PHPUnit)
run: ./vendor/bin/phpunit tests
